{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Upscaler",
  "version": "1.1.0",
  "identifier": "com.seva.proyavka",
  "build": {
    "frontendDist": "../../static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Upscaler",
        "width": 720,
        "height": 880,
        "minWidth": 420,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/realesrgan-ncnn-vulkan"],
    "resources": ["resources/models/*"]
  }
}
